    @template local_smartsearch/result_item

    Example context (json):
    {
        "id": "1",
        "recordid": "42",
        "url": "/course/view.php?id=2",
        "titlehtml": "Example <mark>course</mark>",
        "hassubtitle": true,
        "subtitle": "Category path",
        "hascontextpath": false,
        "hasactions": true,
        "actions": [
            {"url": "/course/view.php?id=2", "label": "View", "icon": "graduation-cap"}
        ]
    }
}}
<div class="smartsearch-result-item" data-id="{{id}}" data-recordid="{{recordid}}">
    <a href="{{url}}" class="smartsearch-result-link">
        <div class="smartsearch-result-title">{{{titlehtml}}}</div>
        {{#hassubtitle}}
        <div class="smartsearch-result-subtitle">{{subtitle}}</div>
        {{/hassubtitle}}
        {{#hascontextpath}}
        <div class="smartsearch-result-context">{{contextpath}}</div>
        {{/hascontextpath}}
    </a>
    {{#hasactions}}
    <div class="smartsearch-result-actions">
        {{#actions}}
        <a href="{{url}}" class="smartsearch-action" title="{{label}}">
            <i class="icon fa fa-{{icon}}"></i>
        </a>
        {{/actions}}
    </div>
    {{/hasactions}}
</div>
