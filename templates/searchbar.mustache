    @template local_smartsearch/searchbar

    Example context (json):
    {
        "searchtitle": "Search (Ctrl+K)"
    }
}}
<div class="smartsearch-bar">
    <button class="btn btn-link smartsearch-trigger h-100"
            type="button"
            title="{{searchtitle}}"
            aria-label="{{searchtitle}}">
        <i class="icon fa fa-search fa-fw" aria-hidden="true"></i>
    </button>
</div>
