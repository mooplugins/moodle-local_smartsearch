    @template local_smartsearch/searchpage

    Example context (json):
    {
        "query": "course",
        "search": "Search",
        "searchplaceholder": "Search users, courses, activities, settings...",
        "resultslabel": "Search results",
        "filterslabel": "Results from",
        "paginationlabel": "Search result pages",
        "filters": [
            {"key": "course", "label": "Courses"},
            {"key": "user", "label": "Users"}
        ]
    }
}}
<div class="smartsearch-page">
    <div id="smartsearch-results-count" class="smartsearch-results-count mb-2" aria-live="polite"></div>
    <div class="smartsearch-page-header">
        <form class="smartsearch-page-form" role="search" action="#" method="get">
            <label class="accesshide" for="smartsearch-page-input">{{searchplaceholder}}</label>
            <input type="text"
                   id="smartsearch-page-input"
                   class="smartsearch-page-input"
                   name="q"
                   value="{{query}}"
                   placeholder="{{searchplaceholder}}"
                   autocomplete="off"
                   aria-label="{{searchplaceholder}}">
            <button class="btn btn-primary smartsearch-page-submit" type="submit">{{search}}</button>
        </form>
        <div class="smartsearch-page-filters" role="group" aria-label="{{filterslabel}}">
            <span class="smartsearch-filters-label">{{filterslabel}}</span>
            {{#filters}}
            <label class="smartsearch-filter">
                <input type="checkbox" class="smartsearch-filter-input" data-recordtype="{{key}}" checked>
                <span>{{label}}</span>
            </label>
            {{/filters}}
        </div>
    </div>
    <div id="smartsearch-page-results"
         class="smartsearch-results"
         role="region"
         aria-live="polite"
         aria-label="{{resultslabel}}"></div>
    <div class="smartsearch-pagination" id="smartsearch-pagination" aria-label="{{paginationlabel}}"></div>
</div>
