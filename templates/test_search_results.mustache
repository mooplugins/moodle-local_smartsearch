    @template local_smartsearch/test_search_results

    Example context (json):
    {
        "hasresults": true,
        "noresults": "No results found",
        "foundlabel": "Found results in 2 categories:",
        "categories": [
            {"name": "course", "count": 3}
        ]
    }
}}
<div class="smartsearch-test-results-panel">
    {{#hasresults}}
    <p><strong>{{foundlabel}}</strong></p>
    <ul>
        {{#categories}}
        <li><strong>{{name}}:</strong> {{count}} results</li>
        {{/categories}}
    </ul>
    {{/hasresults}}
    {{^hasresults}}
    <p>{{noresults}}</p>
    {{/hasresults}}
</div>
